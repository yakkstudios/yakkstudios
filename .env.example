# YAKK Studios — Environment Variables
# Copy this to .env.local for local development
# Set these in Vercel Dashboard > Settings > Environment Variables for production

# ── Solana RPC (REQUIRED for production) ──────────────────────────────────────
# Your private Helius/QuickNode RPC URL. Without this, falls back to public endpoint.
# Get one at https://dev.helius.xyz/dashboard/app
NEXT_PUBLIC_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY_HERE

# ── AI Proxy ──────────────────────────────────────────────────────────────────
# Anthropic API key for the /api/ai endpoint (YAKKAI Coach, etc.)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Optional ──────────────────────────────────────────────────────────────────
# App URL for CORS (defaults to yakkstudios.vercel.app)
# NEXT_PUBLIC_APP_URL=https://yakkstudios.xyz
