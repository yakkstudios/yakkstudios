 app/api/screener/route.ts    |   8 +-
 app/api/stats/route.ts       | 216 +++++++++++++++++++----------------
 components/sections/Wren.tsx |  86 ++++++++------
 lib/constants.ts             |   2 +-
 5 files changed, 249 insertions(+), 177 deletions(-)

